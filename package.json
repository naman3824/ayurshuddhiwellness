{
  "name": "ayurshuddhiwellness",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@11.4.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "dev:main": "turbo run dev --filter=@ayurshuddhi/main",
    "dev:blog": "turbo run dev --filter=@ayurshuddhi/blog",
    "build:main": "turbo run build --filter=@ayurshuddhi/main",
    "build:blog": "turbo run build --filter=@ayurshuddhi/blog"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  }
}
